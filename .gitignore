# pnpm content-addressed store — a build artifact (a stray one can appear at the
# repo root when pnpm is run with a root store-dir); never tracked.
.pnpm-store/

# Loop runtime artifacts written by the supervisor when autonomy-engine runs
# on ITSELF (session logs + the process lock). Anchored to the repo root so the
# committed tests/fixtures/*/var/ fixtures are NOT matched. Without this the
# supervisor's "tree clean on origin/main" preflight would stash/skip forever.
/var/autonomy-logs/
/var/autonomy-supervisor.lock/
/var/cron/
/var/events/
.claude/agents/planner.md
