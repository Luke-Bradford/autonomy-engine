#!/usr/bin/env bash
# ./start -- THE entry point (issue #45). Run it from a fresh checkout and it
# figures out what you need:
#
#   nothing registered yet   ->  setup guidance; `./start /path/to/repo`
#                                chains bin/quickstart.sh on that repo
#                                (guided config, doctor, optional worktree)
#                                and registers it for the dashboard
#   repos registered         ->  one-screen loop-state summary, then the
#                                control-room dashboard (127.0.0.1)
#
# Usage: ./start [target-repo] [--port N] [--no-launch]
#   --no-launch   print the dashboard command instead of running it
#
# Never runs launchctl: loading a supervisor stays a deliberate operator
# step (bin/control.sh start, or the printed go-live lines).
ENGINE_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$ENGINE_HOME/bin/lock_paths.sh"   # single source of the lock pid path (#117)

start_repos_file() { printf '%s' "$HOME/.config/autonomy/repos"; }

# setup | app -- app as soon as anything is registered for the dashboard.
start_mode() {
  local f; f="$(start_repos_file)"
  if [ -f "$f" ] && grep -q '[^[:space:]]' "$f" 2>/dev/null; then
    printf 'app'
  else
    printf 'setup'
  fi
}

start_usage() {
  cat >&2 <<'EOF'
usage: ./start [target-repo] [--port N] [--no-launch] [--foreground]
       ./start console
       ./start status
       ./start stop

`console` runs the engine as ONE foreground service in your terminal: it hosts
the dashboard and streams the live work log (a running log of work). Ctrl-C
stops it; re-run to restart. Cross-platform (Python). `./start console
--interactive` gives a command prompt (status/pause/resume/chat/web) instead.

No repos registered yet: prints setup guidance; with a target-repo argument
it runs the guided quickstart on it (and registers it for the dashboard).
Repos registered: prints the loop-state summary and starts the control-room
dashboard as a managed launchd service (survives the terminal, restarts on
crash/reboot), then opens the browser. --foreground runs it in this terminal
instead (Ctrl-C stops it); --no-launch just prints the command.
`stop` hard-stops the dashboard service. `status` prints a read-only health
report (dashboard, gh auth, repos, loop state, local endpoints, worktree
cleanliness) and exits -- it never binds a port or runs launchctl.
EOF
}

# PIDs of any running control-room dashboard for THIS engine checkout. Anchored
# to $ENGINE_HOME/bin/dashboard.py so a dashboard from a different checkout (or
# an unrelated process merely mentioning the path) is not mistaken for ours.
# `pgrep -f` matches its pattern as a REGEX, so the checkout path is escaped
# first -- otherwise a '.' in it (e.g. '.autonomy-engine-autonomy') would mean
# "any char" and could false-match (prevention-log #6: a string crossing into a
# regex gets neutralized). `|| true`: no match is not an error (never trip the
# caller's set -e). A seam: tests override this function after sourcing.
dashboard_pids() {
  local pat
  pat="$(printf '%s' "$ENGINE_HOME/bin/dashboard.py" | sed 's/[.^$*+?(){}|\\]/\\&/g')"
  pgrep -f "$pat" 2>/dev/null || true
}

# Run a command under a wall-clock cap so a hung network call never wedges the
# health report. macOS bash 3.2 has no `timeout(1)`, so background the command
# and a killer, then wait: whichever the command's own rc (fast path) or a
# non-zero from the TERM (deadline path). Returns the command's rc, or non-zero
# if it was killed -- callers treat non-zero as "unhealthy/unknown", never hang.
#
# Accepted residual (issue #96): the killer targets $cmd_pid by number, so if the
# command finishes at ~exactly the deadline and the OS recycles that pid before we
# tear the killer down, the TERM could hit an unrelated process. The fast path is
# race-free -- the command finishes well inside `sleep "$secs"`, so the killer is
# torn down (line below) long before its `kill` line runs. A portable race-free fix
# needs `wait -n` (bash 4+, barred by the 3.2 floor) or a FIFO+`read -t` rewrite,
# poor risk/reward for a boundary-only near-impossible event on one 5s caller.
# Revisit if this gains more callers or a tighter timeout.
_with_timeout() {
  local secs="$1"; shift
  local cmd_pid killer_pid rc=0
  "$@" &
  cmd_pid=$!
  ( sleep "$secs"; kill -TERM "$cmd_pid" 2>/dev/null ) >/dev/null 2>&1 &
  killer_pid=$!
  wait "$cmd_pid" 2>/dev/null || rc=$?
  kill -TERM "$killer_pid" 2>/dev/null || true
  wait "$killer_pid" 2>/dev/null || true
  return "$rc"
}

# Count of registered repos, guarded so a missing/unreadable/empty repos file
# never aborts under set -e (best-effort: prints 0 on any problem).
start_registered_count() {
  local f n; f="$(start_repos_file)"
  if [ -f "$f" ]; then
    n="$(grep -c '[^[:space:]]' "$f" 2>/dev/null || true)"
  else
    n=0
  fi
  case "$n" in ''|*[!0-9]*) n=0 ;; esac
  printf '%s' "$n"
}

# Names of the registered `openai_compatible` accounts (the BYO-LLM local/remote
# endpoints, #78) -- one per line, empty when none. Best-effort: any problem
# (no python3, absent/corrupt index, parse error) prints nothing rather than
# aborting the report under set -e. A seam: tests shadow this after sourcing.
start_local_accounts() {
  local raw
  raw="$(_with_timeout "${AUTONOMY_ACCT_TIMEOUT:-5}" \
         python3 "$ENGINE_HOME/lib/accounts.py" list 2>/dev/null)" || return 0
  # Parse the accounts.py `list` JSON with the stdlib (no jq); the whole body is
  # read before anything prints, so there is no producer-into-early-exit pipe.
  python3 -c 'import sys, json
try:
    for a in json.load(sys.stdin):
        if a.get("kind") == "openai_compatible":
            print(a["name"])
except Exception:
    pass' <<<"$raw" 2>/dev/null || true
}

# How many models the named endpoint advertises right now (GET <base_url>/models
# via accounts.py list-models), bounded so a hung endpoint can't wedge the
# report. Prints an integer; 0 on unreachable/empty/any error. A seam: tests
# shadow this after sourcing.
start_endpoint_model_count() {
  local name="$1" out cnt
  out="$(_with_timeout "${AUTONOMY_ENDPOINT_TIMEOUT:-8}" \
         python3 "$ENGINE_HOME/lib/accounts.py" list-models "$name" 2>/dev/null)" \
    || { printf '0'; return 0; }
  # list-models prints one id per line; count the non-blank ones. grep -c reads
  # all of the here-string (no early exit), so no SIGPIPE (prevention-log #7).
  # NB grep -c prints "0" AND exits 1 on zero matches -- swallow that rc (it is
  # the empty/unreachable case, not an error) instead of printing a second 0.
  cnt="$(grep -c '[^[:space:]]' <<<"$out" 2>/dev/null)" || true
  case "$cnt" in ''|*[!0-9]*) cnt=0 ;; esac
  printf '%s' "$cnt"
}

# Registered repo paths (the loop worktrees the supervisors run in), one per
# line, blank-line tolerant; empty when the registry is absent/unreadable. This
# is the SAME registry control.sh drives and dashboard.py discovers from, so the
# health report can't desync from the real control surface. Best-effort: any
# problem prints nothing rather than aborting the report. A seam: tests shadow it.
start_registered_repos() {
  local f; f="$(start_repos_file)"
  [ -f "$f" ] || return 0
  grep -v '^[[:space:]]*$' "$f" 2>/dev/null || true
}

# Prints a registered worktree's cleanliness: `clean`, `dirty`, or `unknown`.
# `unknown` (missing path, not a git repo, git error, or a _with_timeout kill)
# is DELIBERATELY distinct from `clean`: the health report must never present an
# uninspectable worktree as healthy -- fail-safe, never fail-open (invariant #1).
# Bounded by _with_timeout so a huge/slow repo can't wedge the report. A seam:
# tests shadow it.
start_worktree_status() {
  local repo="$1" out rc
  [ -d "$repo" ] || { printf 'unknown'; return 0; }
  # Declare-then-assign (not `local out=$(...)`) so `$?` reflects the command's
  # rc, not the `local` builtin's (prevention-log #2). `git status --porcelain`
  # exits 0 for BOTH clean and dirty (empty vs one line per change) and non-zero
  # only on error, so rc!=0 is the genuine "can't tell" case -> unknown.
  out="$(_with_timeout "${AUTONOMY_GIT_TIMEOUT:-5}" git -C "$repo" status --porcelain 2>/dev/null)"; rc=$?
  if [ "$rc" -ne 0 ]; then printf 'unknown'; return 0; fi
  if [ -n "$out" ]; then printf 'dirty'; else printf 'clean'; fi
}

# The argv of a live process (empty if gone). Seam so the supervisor-confirmation
# in start_loop_running is testable without spawning a real supervisor. `ps -o
# command= -p` is portable to macOS bash 3.2 (BSD ps) and Linux (procps).
start_pid_command() {
  ps -o command= -p "$1" 2>/dev/null || printf ''
}

# rc 0 iff $1's loop is genuinely running -- from the supervisor's own lock pid,
# the same lock control.sh's ctl_loop_state reads. But a live pid ALONE is not
# proof: a stale lock's pid could have been reused by an unrelated process, and
# here a false "running" would SUPPRESS the dirty-worktree WARN below (fail-open,
# the direction invariant #1 forbids). So we additionally confirm the live
# process really is THIS repo's supervisor -- its argv carries `supervisor.sh`
# AND this repo path (how the plist/quickstart launch it). Anything unconfirmed
# reads not-running, so the WARN still fires. (ctl_loop_state can skip this: it
# only labels state cosmetically; here the state gates a health warning.) Paused
# counts as not-running on purpose -- a paused loop should have finished its
# in-flight session. A seam: tests shadow it.
start_loop_running() {
  local repo="$1" pid cmd
  pid="$(cat "$(supervisor_lock_pid_file "$repo")" 2>/dev/null || printf '')"
  [ -n "$pid" ] || return 1
  case "$pid" in *[!0-9]*) return 1 ;; esac   # guard kill -0 against a junk pid
  kill -0 "$pid" 2>/dev/null || return 1
  cmd="$(start_pid_command "$pid")"
  # Match the EXACT launch sequence `supervisor.sh --repo <repo>`, with <repo>
  # terminated by a space or end-of-argv -- not loose substrings. A loose
  # `*supervisor.sh*` + `*<repo>*` would false-match `vim .../bin/supervisor.sh`
  # or a supervisor for `<repo>2` when checking `<repo>`, and a false "running"
  # suppresses the dirty WARN (fail-open). The quoted parts are literal, so a
  # path glob metachar can't widen the match (prevention-log #6). Anything that
  # doesn't match reads not-running, so the WARN still fires (fail-safe).
  case "$cmd" in
    *"/supervisor.sh --repo $repo") return 0 ;;    # repo is the final arg
    *"/supervisor.sh --repo $repo "*) return 0 ;;  # repo followed by more args
    *) return 1 ;;
  esac
}

# Prints a registered loop's lifecycle state: running | paused | stopped (#81).
# Mirrors control.sh:ctl_loop_state's vocabulary so the report and the control
# surface agree, but is built on the identity-confirmed start_loop_running (not
# bare pid liveness) -- a recycled lock pid must not mislabel a dead loop as
# running/paused. The supervisor idles ALIVE while paused (its pause loop sleeps
# and re-checks the sentinel), so a confirmed-live supervisor with the PAUSE
# sentinel present is `paused`, without it `running`; anything unconfirmed is
# `stopped` (fail-safe: an uncertain state reads stopped, never a false running).
# The PAUSE sentinel path matches control.sh/supervisor.sh's convention. A seam:
# tests shadow it.
start_loop_state() {
  local repo="$1"
  if start_loop_running "$repo"; then
    if [ -f "$repo/var/autonomy-logs/autonomy-PAUSE" ]; then
      printf 'paused'
    else
      printf 'running'
    fi
  else
    printf 'stopped'
  fi
}

# Read-only live-health report (issue #81). Doctor-style OK/WARN lines; always
# succeeds (health is in the text, not the exit code) and touches nothing --
# no port bind, no launchctl, no dashboard launch.
start_status_report() {
  echo "== autonomy engine health =="
  local pids; pids="$(dashboard_pids)"
  if [ -n "$pids" ]; then
    echo "OK   dashboard running (pid $(printf '%s' "$pids" | tr '\n' ' ' | sed 's/ *$//'); stop: ./start stop)"
  else
    echo "WARN dashboard not running -- './start' starts it as a background service (./start stop to stop)"
  fi
  # Bounded so a slow/hung `gh` (network) never wedges the health report.
  if _with_timeout "${AUTONOMY_GH_TIMEOUT:-5}" gh auth status >/dev/null 2>&1; then
    echo "OK   gh auth ok"
  else
    echo "WARN gh auth not authenticated (or unreachable) -- run 'gh auth login' (need repo + project scopes)"
  fi
  local n; n="$(start_registered_count)"
  if [ "$n" -gt 0 ]; then
    echo "OK   $n repo(s) registered"
    # Per-loop lifecycle state (#81): fold the running/paused/stopped state that
    # 'bin/control.sh list' reports into this report so the operator doesn't need
    # a second command. None of the three is unhealthy on its own (a stopped loop
    # may be deliberately off; a paused one is a graceful hold), so each is an
    # informational OK line -- the genuinely-bad case (dirty tree while stopped)
    # is a separate WARN below. Fed from a command substitution (not a pipe) so
    # nothing runs in a subshell (prevention-log #7). start_loop_state is
    # identity-confirmed and fail-safe (an unconfirmable loop reads stopped).
    local lrepo lstate
    while IFS= read -r lrepo; do
      [ -n "$lrepo" ] || continue
      lstate="$(start_loop_state "$lrepo")"
      case "$lstate" in
        running) echo "OK   loop running -- $lrepo" ;;
        paused)  echo "OK   loop paused -- $lrepo (resume: bin/control.sh resume $lrepo)" ;;
        *)       echo "OK   loop stopped -- $lrepo (start: bin/control.sh start $lrepo)" ;;
      esac
    done <<EOF
$(start_registered_repos)
EOF
  else
    echo "WARN no repos registered -- './start /path/to/repo' to onboard one"
  fi
  # Local (BYO-LLM, #78) endpoints: stay silent unless the operator configured
  # one -- no noise for the common cloud-only setup. Fed from a command
  # substitution (not a pipe) so the loop body runs in this shell, not a
  # subshell. #81 asked specifically for an 'is my ollama reachable?' signal.
  local acct cnt
  while IFS= read -r acct; do
    [ -n "$acct" ] || continue
    cnt="$(start_endpoint_model_count "$acct")"
    case "$cnt" in ''|*[!0-9]*) cnt=0 ;; esac
    if [ "$cnt" -gt 0 ]; then
      echo "OK   local endpoint '$acct' reachable ($cnt model(s))"
    else
      echo "WARN local endpoint '$acct' unreachable or advertises no models -- start it (e.g. 'ollama serve') or check its base_url"
    fi
  done <<EOF
$(start_local_accounts)
EOF
  # Loop-worktree cleanliness (#81): a loop is meant to leave a clean tree
  # between iterations, so a registered worktree that's dirty while its loop is
  # NOT running is a real "half-done / wedged session" signal. A running loop is
  # legitimately dirty mid-session -- flagging it would be noise, so skip it. An
  # uninspectable worktree (`unknown`) is flagged too, never counted as clean
  # (fail-safe, never fail-open). Fed from a command substitution (not a pipe)
  # so the counters live in this shell (prevention-log #7: no early-exit pipe).
  #
  # start_registered_repos yields empty for BOTH an absent and an unreadable
  # registry. Silently skipping cleanliness on an unreadable-but-present registry
  # would hide dirty/uninspectable worktrees -- fail-open. Disambiguate here: a
  # registry that exists but can't be read WARNs (still exits 0); an absent one
  # is the legitimate no-repos case and stays silent.
  local reg; reg="$(start_repos_file)"
  if [ -f "$reg" ] && [ ! -r "$reg" ]; then
    echo "WARN loop-worktree registry $reg exists but is unreadable -- can't check worktree cleanliness; fix its permissions"
    return 0
  fi
  local repo checked_n=0 flagged_n=0 st
  while IFS= read -r repo; do
    [ -n "$repo" ] || continue
    checked_n=$((checked_n + 1))
    st="$(start_worktree_status "$repo")"
    case "$st" in
      dirty)
        # A running loop's dirt is expected; only a stopped/paused one is a mess.
        if ! start_loop_running "$repo"; then
          flagged_n=$((flagged_n + 1))
          echo "WARN loop worktree '$repo' has uncommitted changes and its loop is not running -- a finished loop should leave a clean tree; inspect 'git -C $repo status'"
        fi
        ;;
      unknown)
        flagged_n=$((flagged_n + 1))
        echo "WARN loop worktree '$repo' could not be inspected (missing path, not a git repo, or git timed out) -- check the registered path, then 'git -C $repo status'"
        ;;
      *) : ;;   # clean -> nothing to say; the aggregate line below covers it
    esac
  done <<EOF
$(start_registered_repos)
EOF
  if [ "$checked_n" -gt 0 ] && [ "$flagged_n" -eq 0 ]; then
    echo "OK   $checked_n loop worktree(s) healthy (none dirty while stopped, all inspectable)"
  fi
}

# --- dashboard-as-a-service (#81) -------------------------------------------
# The control-room dashboard runs as a launchd LaunchAgent so it's a persistent
# background app (survives the terminal, restarts on crash/reboot) rather than a
# foreground script. Supervisors stay a deliberate step; the dashboard is a
# read-only loopback UI, so auto-running it is safe. launchctl is the boundary
# (seams below let tests drive the pure render without loading anything).
dashboard_service_label() { printf 'com.autonomy.dashboard'; }
dashboard_plist_dst() { printf '%s' "$HOME/Library/LaunchAgents/com.autonomy.dashboard.plist"; }
dashboard_log_dir() { printf '%s' "$HOME/.config/autonomy"; }

# Render the plist template with this checkout's python/engine-home/port/log-dir.
# Pure (template + args -> stdout); '#' sed delimiter since paths carry '/'.
render_dashboard_plist() {
  local port="$1" py tmpl
  py="$(command -v python3 || printf '/usr/bin/python3')"
  tmpl="$ENGINE_HOME/templates/dashboard.plist.tmpl"
  sed -e "s#__PYTHON__#${py}#g" \
      -e "s#__ENGINE_HOME__#${ENGINE_HOME}#g" \
      -e "s#__PORT__#${port}#g" \
      -e "s#__LOG_DIR__#$(dashboard_log_dir)#g" \
      "$tmpl"
}

# Install + (re)load the service. Idempotent: bootout-then-bootstrap so a
# re-run picks up a new port/checkout. A seam: tests shadow it.
dashboard_service_load() {
  local port="$1" dst uid
  mkdir -p "$(dashboard_log_dir)" 2>/dev/null || true
  dst="$(dashboard_plist_dst)"
  mkdir -p "$(dirname "$dst")" 2>/dev/null || true
  render_dashboard_plist "$port" > "$dst" || return 1
  uid="$(id -u)"
  launchctl bootout "gui/$uid/$(dashboard_service_label)" 2>/dev/null || true
  launchctl bootstrap "gui/$uid" "$dst"
}

# Hard-stop the service (bootout). KeepAlive means only launchctl actually stops
# it -- pkill would just be restarted. A seam: tests shadow it.
dashboard_service_stop() {
  launchctl bootout "gui/$(id -u)/$(dashboard_service_label)" 2>/dev/null || true
}

[ "${BASH_SOURCE[0]}" = "${0}" ] || return 0

set -euo pipefail

# `status` subcommand: read-only health report, then exit. Handled before the
# arg loop so it works in setup mode too (no repos) and never falls through to
# the launch path. Takes no further args -- reject them rather than ignore.
if [ "${1:-}" = "status" ]; then
  shift
  if [ "$#" -ne 0 ]; then
    echo "start: 'status' takes no arguments" >&2; start_usage; exit 2
  fi
  start_status_report
  exit 0
fi

# `stop` subcommand: hard-stop the dashboard service (bootout). Handled before
# the arg loop; takes no further args.
if [ "${1:-}" = "stop" ]; then
  shift
  if [ "$#" -ne 0 ]; then
    echo "start: 'stop' takes no arguments" >&2; start_usage; exit 2
  fi
  dashboard_service_stop
  echo "control-room dashboard stopped (service $(dashboard_service_label) booted out)."
  exit 0
fi

# `console` subcommand: the foreground terminal control app (launches the
# dashboard, streams logs, takes commands, Ctrl-C to stop). Cross-platform
# Python -- the visible, hard-killable "running application" surface.
if [ "${1:-}" = "console" ]; then
  shift
  exec python3 "$ENGINE_HOME/bin/console.py" "$@"
fi

TARGET=""
PORT=""
NO_LAUNCH=0
FOREGROUND=0
while [ $# -gt 0 ]; do
  case "$1" in
    --port)      PORT="${2:?--port needs a value}"; shift 2 ;;
    --no-launch) NO_LAUNCH=1; shift ;;
    --foreground) FOREGROUND=1; shift ;;
    -h|--help)   start_usage; exit 0 ;;
    -*)          echo "start: unknown flag $1" >&2; start_usage; exit 2 ;;
    *)           if [ -z "$TARGET" ]; then TARGET="$1"; shift
                 else echo "start: unexpected argument $1" >&2; start_usage; exit 2; fi ;;
  esac
done

SETUP_FAILED=0
if [ -n "$TARGET" ]; then
  [ -d "$TARGET" ] || { echo "start: target '$TARGET' is not a directory" >&2; exit 2; }
  echo "== setup: guided quickstart for $TARGET =="
  # --register yes is the point of coming through ./start: the repo appears
  # in the dashboard's discovery and this machine flips to app mode.
  if ! "$ENGINE_HOME/bin/quickstart.sh" "$TARGET" --register yes; then
    echo "start: quickstart reported problems above -- fix them, then re-run ./start" >&2
    SETUP_FAILED=1
  fi
  echo ""
fi

if [ "$(start_mode)" = "setup" ]; then
  cat <<EOF
== autonomy engine: nothing set up on this machine yet ==

No repos are registered in $(start_repos_file).

To bring a repo under the engine (guided -- scaffolds the pack, walks the
minimum config, runs the readiness report, registers it here):

  $ENGINE_HOME/start /path/to/your-repo

Or drive the pieces yourself: bin/quickstart.sh, bin/doctor.sh,
bin/setup_worktree.sh, bin/control.sh (see README.md).
EOF
  exit "$SETUP_FAILED"
fi

echo "== autonomy control room =="
"$ENGINE_HOME/bin/control.sh" list || true
echo ""

# One source of truth for the dashboard invocation: printed by --no-launch,
# run as a service by default, exec'd foreground with --foreground.
# Port precedence: --port flag > ~/.config/autonomy/settings (port = N) > 8787,
# so `./start`, the double-click launcher, and the console all agree on it.
if [ -z "${PORT:-}" ]; then   # ${PORT:-} : set-u-safe even if PORT were never set
  PORT="$(python3 "$ENGINE_HOME/lib/settings.py" port 2>/dev/null)"
  case "$PORT" in ''|*[!0-9]*) PORT=8787 ;; esac
fi
DASH_ARGV=(python3 "$ENGINE_HOME/bin/dashboard.py" --port "$PORT")

if [ "$SETUP_FAILED" -ne 0 ]; then
  echo "setup reported problems above -- not launching the dashboard. When fixed:"
  printf '  '; printf '%q ' "${DASH_ARGV[@]}"; printf '\n'
  exit 1
fi
if [ "$NO_LAUNCH" -eq 1 ]; then
  echo "dashboard (not launched, --no-launch):"
  printf '  '; printf '%q ' "${DASH_ARGV[@]}"; printf '\n'
  exit 0
fi
if [ "$FOREGROUND" -eq 1 ]; then
  echo "launching the dashboard in the foreground (Ctrl-C stops it; loops unaffected) ..."
  exec "${DASH_ARGV[@]}"
fi

# Default: a managed launchd service -- survives this terminal, restarts on
# crash/reboot, hard-stopped with './start stop'.
echo "starting the control-room dashboard as a background service ..."
if dashboard_service_load "$PORT"; then
  echo "OK   dashboard live at http://127.0.0.1:$PORT/  (service $(dashboard_service_label))"
  echo "     stop:  ./start stop     health:  ./start status     foreground:  ./start --foreground"
  if command -v open >/dev/null 2>&1; then open "http://127.0.0.1:$PORT/" 2>/dev/null || true; fi
else
  echo "start: could not load the launchd service -- running foreground instead (Ctrl-C stops it)" >&2
  exec "${DASH_ARGV[@]}"
fi
