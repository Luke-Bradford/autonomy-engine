{
  "name": "ticket-to-merge",
  "version": 2,
  "trigger_default": {"type": "loop"},
  "caps": {"max_sessions_per_run": 16},
  "nodes": [
    {"id": "pick", "type": "pick", "brief_ref": "pick.md"},
    {"id": "plan", "type": "plan", "brief_ref": "plan.md"},
    {"id": "code", "type": "agent_task", "brief_ref": "code.md"},
    {"id": "test-vs-plan", "type": "check", "brief_ref": "test-vs-plan.md"},
    {"id": "open-pr", "type": "git_ops", "brief_ref": "open-pr.md"},
    {"id": "qa-gather", "type": "gather", "brief_ref": "qa-gather.md"},
    {"id": "verify", "type": "check", "brief_ref": "verify.md"},
    {"id": "breakage", "type": "check", "brief_ref": "breakage.md"},
    {"id": "qa-review", "type": "check", "brief_ref": "qa-review.md"},
    {"id": "qa-verdict", "type": "check", "brief_ref": "qa-verdict.md"},
    {"id": "notify-park", "type": "notify", "brief_ref": "notify-park.md",
     "join": "any"},
    {"id": "summarize", "type": "summarize", "brief_ref": "summarize.md"},
    {"id": "journal-run", "type": "journal", "brief_ref": "journal-run.md",
     "join": "any"}
  ],
  "edges": [
    {"from": "pick", "to": "plan", "on": "success"},
    {"from": "plan", "to": "coding", "on": "success"},
    {"from": "coding", "to": "open-pr", "on": "success"},
    {"from": "open-pr", "to": "qa-gather", "on": "success"},
    {"from": "qa-gather", "to": "verify", "on": "success"},
    {"from": "qa-gather", "to": "breakage", "on": "success"},
    {"from": "qa-gather", "to": "qa-review", "on": "success"},
    {"from": "verify", "to": "qa-verdict", "on": "success"},
    {"from": "breakage", "to": "qa-verdict", "on": "success"},
    {"from": "qa-review", "to": "qa-verdict", "on": "success"},
    {"from": "verify", "to": "notify-park", "on": "failure"},
    {"from": "breakage", "to": "notify-park", "on": "failure"},
    {"from": "qa-review", "to": "notify-park", "on": "failure"},
    {"from": "qa-verdict", "to": "coding", "on": "failure", "back": true,
     "max_bounces": 3},
    {"from": "qa-verdict", "to": "summarize", "on": "success"},
    {"from": "summarize", "to": "journal-run", "on": "completion"},
    {"from": "notify-park", "to": "journal-run", "on": "completion"}
  ],
  "containers": [
    {"id": "coding", "kind": "loop", "children": ["code", "test-vs-plan"],
     "exit_when": "every test criterion named in the plan passes",
     "max_rounds": 5}
  ]
}
