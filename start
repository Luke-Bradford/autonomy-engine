#!/usr/bin/env bash
# ./start -- THE entry point (issue #45). Run it from a fresh checkout and it
# figures out what you need:
#
#   nothing registered yet   ->  setup guidance; `./start /path/to/repo`
#                                chains bin/quickstart.sh on that repo
#                                (guided config, doctor, optional worktree)
#                                and registers it for the dashboard
#   repos registered         ->  one-screen loop-state summary, then the
#                                control-room dashboard (127.0.0.1)
#
# Usage: ./start [target-repo] [--port N] [--no-launch]
#   --no-launch   print the dashboard command instead of running it
#
# Never runs launchctl: loading a supervisor stays a deliberate operator
# step (bin/control.sh start, or the printed go-live lines).
ENGINE_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

start_repos_file() { printf '%s' "$HOME/.config/autonomy/repos"; }

# setup | app -- app as soon as anything is registered for the dashboard.
start_mode() {
  local f; f="$(start_repos_file)"
  if [ -f "$f" ] && grep -q '[^[:space:]]' "$f" 2>/dev/null; then
    printf 'app'
  else
    printf 'setup'
  fi
}

start_usage() {
  cat >&2 <<'EOF'
usage: ./start [target-repo] [--port N] [--no-launch]
       ./start status

No repos registered yet: prints setup guidance; with a target-repo argument
it runs the guided quickstart on it (and registers it for the dashboard).
Repos registered: prints the loop-state summary and runs the control-room
dashboard. --no-launch prints the dashboard command instead of running it.
`status` prints a read-only health report (dashboard process, gh auth, repo
registration) and exits -- it never binds a port or runs launchctl.
EOF
}

# PIDs of any running control-room dashboard for THIS engine checkout. Anchored
# to $ENGINE_HOME/bin/dashboard.py so a dashboard from a different checkout (or
# an unrelated process merely mentioning the path) is not mistaken for ours.
# `pgrep -f` matches its pattern as a REGEX, so the checkout path is escaped
# first -- otherwise a '.' in it (e.g. '.autonomy-engine-autonomy') would mean
# "any char" and could false-match (prevention-log #6: a string crossing into a
# regex gets neutralized). `|| true`: no match is not an error (never trip the
# caller's set -e). A seam: tests override this function after sourcing.
dashboard_pids() {
  local pat
  pat="$(printf '%s' "$ENGINE_HOME/bin/dashboard.py" | sed 's/[.^$*+?(){}|\\]/\\&/g')"
  pgrep -f "$pat" 2>/dev/null || true
}

# Count of registered repos, guarded so a missing/unreadable/empty repos file
# never aborts under set -e (best-effort: prints 0 on any problem).
start_registered_count() {
  local f n; f="$(start_repos_file)"
  if [ -f "$f" ]; then
    n="$(grep -c '[^[:space:]]' "$f" 2>/dev/null || true)"
  else
    n=0
  fi
  case "$n" in ''|*[!0-9]*) n=0 ;; esac
  printf '%s' "$n"
}

# Read-only live-health report (issue #81). Doctor-style OK/WARN lines; always
# succeeds (health is in the text, not the exit code) and touches nothing --
# no port bind, no launchctl, no dashboard launch.
start_status_report() {
  echo "== autonomy engine health =="
  local pids; pids="$(dashboard_pids)"
  if [ -n "$pids" ]; then
    echo "OK   dashboard running (pid $(printf '%s' "$pids" | tr '\n' ' ' | sed 's/ *$//'))"
  else
    echo "WARN dashboard not running -- './start' launches it; hard-kill: pkill -f bin/dashboard.py"
  fi
  if gh auth status >/dev/null 2>&1; then
    echo "OK   gh auth ok"
  else
    echo "WARN gh auth not authenticated -- run 'gh auth login' (need repo + project scopes)"
  fi
  local n; n="$(start_registered_count)"
  if [ "$n" -gt 0 ]; then
    echo "OK   $n repo(s) registered -- 'bin/control.sh list' for per-loop state"
  else
    echo "WARN no repos registered -- './start /path/to/repo' to onboard one"
  fi
}

[ "${BASH_SOURCE[0]}" = "${0}" ] || return 0

set -euo pipefail

# `status` subcommand: read-only health report, then exit. Handled before the
# arg loop so it works in setup mode too (no repos) and never falls through to
# the launch path. Takes no further args -- reject them rather than ignore.
if [ "${1:-}" = "status" ]; then
  shift
  if [ "$#" -ne 0 ]; then
    echo "start: 'status' takes no arguments" >&2; start_usage; exit 2
  fi
  start_status_report
  exit 0
fi

TARGET=""
PORT=""
NO_LAUNCH=0
while [ $# -gt 0 ]; do
  case "$1" in
    --port)      PORT="${2:?--port needs a value}"; shift 2 ;;
    --no-launch) NO_LAUNCH=1; shift ;;
    -h|--help)   start_usage; exit 0 ;;
    -*)          echo "start: unknown flag $1" >&2; start_usage; exit 2 ;;
    *)           if [ -z "$TARGET" ]; then TARGET="$1"; shift
                 else echo "start: unexpected argument $1" >&2; start_usage; exit 2; fi ;;
  esac
done

SETUP_FAILED=0
if [ -n "$TARGET" ]; then
  [ -d "$TARGET" ] || { echo "start: target '$TARGET' is not a directory" >&2; exit 2; }
  echo "== setup: guided quickstart for $TARGET =="
  # --register yes is the point of coming through ./start: the repo appears
  # in the dashboard's discovery and this machine flips to app mode.
  if ! "$ENGINE_HOME/bin/quickstart.sh" "$TARGET" --register yes; then
    echo "start: quickstart reported problems above -- fix them, then re-run ./start" >&2
    SETUP_FAILED=1
  fi
  echo ""
fi

if [ "$(start_mode)" = "setup" ]; then
  cat <<EOF
== autonomy engine: nothing set up on this machine yet ==

No repos are registered in $(start_repos_file).

To bring a repo under the engine (guided -- scaffolds the pack, walks the
minimum config, runs the readiness report, registers it here):

  $ENGINE_HOME/start /path/to/your-repo

Or drive the pieces yourself: bin/quickstart.sh, bin/doctor.sh,
bin/setup_worktree.sh, bin/control.sh (see README.md).
EOF
  exit "$SETUP_FAILED"
fi

echo "== autonomy control room =="
"$ENGINE_HOME/bin/control.sh" list || true
echo ""

# One source of truth for the dashboard invocation: printed by --no-launch,
# exec'd otherwise (PR #46 review).
DASH_ARGV=(python3 "$ENGINE_HOME/bin/dashboard.py")
if [ -n "$PORT" ]; then DASH_ARGV+=(--port "$PORT"); fi

if [ "$SETUP_FAILED" -ne 0 ]; then
  echo "setup reported problems above -- not launching the dashboard. When fixed:"
  printf '  '; printf '%q ' "${DASH_ARGV[@]}"; printf '\n'
  exit 1
fi
if [ "$NO_LAUNCH" -eq 1 ]; then
  echo "dashboard (not launched, --no-launch):"
  printf '  '; printf '%q ' "${DASH_ARGV[@]}"; printf '\n'
  exit 0
fi

echo "launching the dashboard (Ctrl-C stops it; loops are unaffected) ..."
exec "${DASH_ARGV[@]}"
